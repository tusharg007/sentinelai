# AuricVision Backend Environment Configuration
# Copy to .env and fill in secrets

# ── App ───────────────────────────────────────────────────────────
ENV=development
# Change to: production

# ── Security ──────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-32chars!!
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"

# ── Compute ───────────────────────────────────────────────────────
DEVICE=auto
# Options: auto | cpu | cuda | mps

# ── Models ────────────────────────────────────────────────────────
ENABLE_MODELS=detector,change_backbone
DETECTOR_MODEL=yolov8n.pt
# Production: yolov8l.pt or DOTA-finetuned weights

# ── Inference ─────────────────────────────────────────────────────
DETECT_CONFIDENCE=0.25
